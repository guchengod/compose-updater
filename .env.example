# Bark 设备 Key。bark.enabled=false 时可以不配置。
BARK_DEVICE_KEY=

# 日志级别：debug / info / warn / error
LOG_LEVEL=info

# 默认 docker。原生运行时可写绝对路径。
DOCKER_COMMAND=docker

# 锁文件目录。
COMPOSE_UPDATER_DATA_DIR=/data

# 显式排除更新器自身的 Compose 文件；多个路径使用系统 PathList 分隔符。
COMPOSE_UPDATER_SKIP_FILES=/opt/compose-updater/compose.yml

# Docker 运行中心登录信息。使用 compose.example.yaml 时必须修改密码。
COMPOSE_UPDATER_WEB_USERNAME=admin
COMPOSE_UPDATER_WEB_PASSWORD=

# 私有 HTTP Registry 时配置，逗号分隔。生产环境优先使用 HTTPS。
COMPOSE_UPDATER_INSECURE_REGISTRIES=

# 高级超时参数，通常无需修改。
COMPOSE_UPDATER_CONFIG_TIMEOUT=90s
COMPOSE_UPDATER_REGISTRY_TIMEOUT=2m
COMPOSE_UPDATER_PULL_TIMEOUT=15m
COMPOSE_UPDATER_UPDATE_TIMEOUT=10m
COMPOSE_UPDATER_HEALTH_TIMEOUT=3m
COMPOSE_UPDATER_HEALTH_POLL_INTERVAL=3s
COMPOSE_UPDATER_STABLE_DURATION=10s
COMPOSE_UPDATER_NOTIFY_TIMEOUT=15s
